{
  "framework": "vite",
  "installCommand": "npm install",
  "buildCommand": "rm -rf dist .vite node_modules/.vite && npm run check-env && npm run build",
  "outputDirectory": "dist",
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
